# === Authentication (choose ONE mode) ===

# Mode 1: API Key (standard Anthropic API key)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Mode 2: OAuth Token (from 'claude login' session)
# Option A: Set the token directly
# ANTHROPIC_AUTH_TOKEN=xxxx.yyyy
# Option B: Read from file (default: ~/.claude/settings.json)
# CLAUDE_CREDENTIALS_FILE=~/.claude/settings.json

# Advanced: override auth header name (auto-detected by mode)
# AUTH_HEADER_NAME=authorization

# Token auto-refresh interval in seconds (0 = only refresh on 401)
# TOKEN_REFRESH_INTERVAL=0

# === Server ===
PORT=3456
TARGET_URL=https://api.anthropic.com
